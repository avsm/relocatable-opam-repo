license: "LGPL-2.1-or-later WITH OCaml-LGPL-linking-exception"
synopsis: "OxCaml (one-shot relocatable bundle build)"
description: """
OxCaml 5.2.0minus38, built from the self-contained, pre-unpacked and
pre-patched source bundle published by oxcaml-pkgs at
https://oi.thicket.dev/repo/src/."""
maintainer: "Anil Madhavapeddy <anil@recoil.org>"
authors: "Xavier Leroy and many contributors"
homepage: "https://oxcaml.org"
bug-reports: "https://github.com/oxcaml/oxcaml/issues"
dev-repo: "git+https://github.com/oxcaml/oxcaml.git#main"
depends: [
  "conf-autoconf"         {build}
  "conf-which"            {build}
  "ocaml-variants"        {= "5.2.0+ox" & post}
  "oxcaml"                {post}
  "base-unix"             {post}
  "base-bigarray"         {post}
  "base-threads"          {post}
  "base-domains"          {post}
  "base-nnp"              {post}
  "ocaml-options-vanilla" {post}
  "oxcaml-patch-guards"   {post}
]
setenv: CAML_LD_LIBRARY_PATH = "%{lib}%/stublibs"
build: [
  [make "PREFIX=%{prefix}%" "JOBS=%{jobs}%"]
]
install: [
  [make "install" "PREFIX=%{prefix}%"]
]
